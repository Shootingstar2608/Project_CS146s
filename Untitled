#  Autonomous Graph-RAG Agent — Environment Variables     
#  Copy to .env and fill in your values                   

# LLM Provider 
# Option 1: Groq (Free tier — recommended for dev)
GROQ_API_KEY=gsk_your_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Option 2: Ollama (Local — recommended for demo)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# LLM_MODEL=llama3.1:8b

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag_secret_2024

# PostgreSQL 
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_2024
POSTGRES_DB=graphrag
POSTGRES_URL=postgresql+asyncpg://postgres:postgres_secret_2024@postgres:5432/graphrag

# Redis (Celery broker)
REDIS_URL=redis://redis:6379/0

# Application
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=50
