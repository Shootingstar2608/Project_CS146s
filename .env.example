#  Autonomous Graph-RAG Agent — Environment Variables
#  Copy to .env and fill in your values

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option 1: Groq (Free tier — recommended for dev)
GROQ_API_KEY=gsk_your_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Option 2: Ollama (Local — zero API cost)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# LLM_MODEL=llama3.1:8b

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag_secret_2024

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secret_2024
POSTGRES_DB=graphrag
POSTGRES_URL=postgresql+asyncpg://postgres:postgres_secret_2024@postgres:5432/graphrag

# ── Redis (Celery broker) ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=50

# ── Vector Search / Embeddings (NEW) ─────────────────────────────────────────
# Directory where FAISS index is persisted (relative to project root or absolute)
VECTOR_STORE_PATH=data/faiss

# SentenceTransformers model name (all-MiniLM-L6-v2 = 384-dim, ~80MB, MIT)
# Alternatives: all-mpnet-base-v2 (768-dim, more accurate but slower)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Chunk settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Top-k vector candidates per query step
VECTOR_TOP_K=5

# ── Hybrid Fusion (NEW) ───────────────────────────────────────────────────────
# Default alpha: 0.0 = pure KG, 1.0 = pure vector, 0.5 = balanced
# Overridden per-query by the router or API caller
HYBRID_ALPHA=0.5

# RRF constant k (higher = less sensitive to top-rank dominance)
RRF_K=60

# ── Re-ranking (Bonus, NEW) ───────────────────────────────────────────────────
# Enable cross-encoder re-ranking of top candidates (~100ms extra latency)
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=5
